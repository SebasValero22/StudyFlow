<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<VBox spacing="25.0" style="-fx-background-color: white; -fx-padding: 30;" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.ExamFormController">
    <children>
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Schedule New Exam" />
                <Label style="-fx-text-fill: #7f8c8d;" text="Enter exam details to track upcoming assessments" />
            </children>
        </VBox>

        <GridPane hgap="20.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints prefWidth="120.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Subject" />
                <ComboBox fx:id="subjectCombo" prefHeight="40.0" prefWidth="Infinity" promptText="Select subject" style="-fx-background-color: #f1f3f5;" GridPane.columnIndex="1" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Exam Name" GridPane.rowIndex="1" />
                <TextField fx:id="nameField" prefHeight="40.0" promptText="e.g. Midterm Exam" style="-fx-background-color: #f1f3f5; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Exam Type" GridPane.rowIndex="2" />
                <TextField fx:id="typeField" prefHeight="40.0" promptText="e.g. Final, Partial" style="-fx-background-color: #f1f3f5; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Exam Date" GridPane.rowIndex="3" />
                <DatePicker fx:id="datePicker" prefHeight="40.0" prefWidth="Infinity" style="-fx-background-color: #f1f3f5;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Room / Location" GridPane.rowIndex="4" />
                <TextField fx:id="roomField" prefHeight="40.0" promptText="e.g. Room 204" style="-fx-background-color: #f1f3f5; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </children>
        </GridPane>

        <Label fx:id="statusLabel" wrapText="true" />

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="Cancel" />
                <Button onAction="#handleSave" prefHeight="40.0" prefWidth="150.0" styleClass="action-button" text="Save Exam" />
            </children>
        </HBox>
    </children>
</VBox>