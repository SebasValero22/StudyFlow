<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" styleClass="content-area" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.TaskOverviewController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="My Tasks" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button onAction="#openCreateTaskDialog" styleClass="action-button" text="+ Add New Task" />
            </children>
        </HBox>

        <VBox spacing="15.0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" text="Current Academic Tasks" />
                <TableView fx:id="taskTable" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="80.0" text="Done" />
                        <TableColumn prefWidth="250.0" text="Title">
                            <cellValueFactory><PropertyValueFactory property="title" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn prefWidth="350.0" text="Description">
                            <cellValueFactory><PropertyValueFactory property="description" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colRemaining" prefWidth="100.0" text="Time Left" />
                        <TableColumn prefWidth="120.0" text="Due Date">
                            <cellValueFactory><PropertyValueFactory property="due_date" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn prefWidth="100.0" text="Priority">
                            <cellValueFactory><PropertyValueFactory property="priority" /></cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button onAction="#handleDeleteTask" styleClass="action-button, delete-button" text="Delete Selected" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>