<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<VBox spacing="25.0" style="-fx-background-color: white; -fx-padding: 30;" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.SubjectFormController">
    <children>
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Create New Subject" />
                <Label style="-fx-text-fill: #7f8c8d;" text="Fill in the details to add a subject to your cloud" />
            </children>
        </VBox>

        <GridPane hgap="20.0" vgap="20.0">
            <columnConstraints>
                <ColumnConstraints prefWidth="120.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Subject Name" />
                <TextField fx:id="nameField" prefHeight="40.0" promptText="e.g. Mathematics" style="-fx-background-color: #f1f3f5; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8;" GridPane.columnIndex="1" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Academic Year" GridPane.rowIndex="1" />
                <DatePicker fx:id="academicYearPicker" prefHeight="40.0" prefWidth="Infinity" promptText="Select start date" style="-fx-background-color: #f1f3f5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Color Theme" GridPane.rowIndex="2" />
                <ColorPicker fx:id="colorPicker" prefHeight="40.0" prefWidth="Infinity" style="-fx-background-color: #f1f3f5;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>

        <Label fx:id="formStatusLabel" wrapText="true" />

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="Cancel" />
                <Button onAction="#handleSave" prefHeight="40.0" prefWidth="150.0" styleClass="action-button" text="Add Subject" />
            </children>
        </HBox>
    </children>
</VBox>