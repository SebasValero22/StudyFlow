<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="25.0" styleClass="content-area" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.SubjectsController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Subjects Management" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button onAction="#handleCreateSubject" styleClass="action-button" text="+ Add Subject" />
            </children>
        </HBox>

        <VBox spacing="15.0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" text="Existing Subjects" />
                <TableView fx:id="subjectsTable" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="300.0" text="Subject Name">
                            <cellValueFactory><PropertyValueFactory property="nameSubject" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn prefWidth="200.0" text="Academic Year">
                            <cellValueFactory><PropertyValueFactory property="academicYear" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn prefWidth="150.0" text="Color Code">
                            <cellValueFactory><PropertyValueFactory property="color" /></cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button onAction="#handleDeleteSubject" styleClass="action-button, delete-button" text="Delete Selected" />
                    </children>
                </HBox>
            </children>
        </VBox>
        <Label fx:id="statusLabel" textFill="#7f8c8d" />
    </children>
</VBox>