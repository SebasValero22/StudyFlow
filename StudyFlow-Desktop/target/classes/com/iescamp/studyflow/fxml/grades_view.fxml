<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" styleClass="content-area" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.GradesController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Grades &amp; Performance" />
                <HBox HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" styleClass="card" style="-fx-background-color: #3498db; -fx-padding: 10 20;">
                    <children>
                        <Label fx:id="lblAverage" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="GPA: 0.00" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <VBox spacing="15.0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" text="Academic Grades Record" />
                <TableView fx:id="gradesTable" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colConcept" prefWidth="350.0" text="Concept / Assessment" />
                        <TableColumn fx:id="colScore" prefWidth="120.0" text="Score (0-10)" />
                        <TableColumn fx:id="colWeight" prefWidth="120.0" text="Weight %" />
                        <TableColumn fx:id="colDate" prefWidth="200.0" text="Date Logged" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>