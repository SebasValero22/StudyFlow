<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane prefHeight="600.0" prefWidth="450.0" style="-fx-background-color: #f8f9fa;" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.RegisterController">
   <children>
      <VBox alignment="CENTER" maxWidth="380.0" spacing="20.0" styleClass="card" style="-fx-padding: 40;">
         <children>
            <StackPane styleClass="logo-icon" maxWidth="50" maxHeight="50">
               <children>
                  <Label text="SF" textFill="WHITE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
               </children>
            </StackPane>

            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #2c3e50;" text="Create Account" />
                  <Label style="-fx-text-fill: #7f8c8d;" text="Join the StudyFlow academic cloud" />
               </children>
            </VBox>

            <VBox spacing="12.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Full Name" />
                        <TextField fx:id="nameField" prefHeight="40.0" promptText="Enter your name" style="-fx-background-color: #f1f3f5; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8;" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Email Address" />
                        <TextField fx:id="emailField" prefHeight="40.0" promptText="name@example.com" style="-fx-background-color: #f1f3f5; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8;" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Password" />
                        <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="••••••••" style="-fx-background-color: #f1f3f5; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8;" />
                     </children>
                  </VBox>
               </children>
            </VBox>

            <Button maxWidth="1.7976931348623157E308" onAction="#handleRegister" prefHeight="45.0" styleClass="action-button" text="Create Account" />
            
            <Button onAction="#goToLogin" style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-font-weight: bold;" text="Already have an account? Sign In" />
            
            <Label fx:id="messageLabel" textFill="#e74c3c" wrapText="true" alignment="CENTER" textAlignment="CENTER"/>
         </children>
      </VBox>
   </children>
</StackPane>