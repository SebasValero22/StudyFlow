<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" styleClass="content-area" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.ExamsController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Exams Schedule" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button onAction="#handleEditExam" styleClass="action-button" style="-fx-background-color: #f39c12;" text="Modify" />
                <Button onAction="#handleNewExam" styleClass="action-button" text="+ New Exam" />
            </children>
        </HBox>

        <VBox spacing="15.0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" text="Upcoming Academic Assessments" />
                <TableView fx:id="examsTable" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDone" prefWidth="80.0" text="Done" />
                        <TableColumn fx:id="colRemaining" prefWidth="100.0" text="Time Left" />
                        <TableColumn fx:id="colExamName" prefWidth="300.0" text="Exam Name" />
                        <TableColumn fx:id="colExamType" prefWidth="150.0" text="Type" />
                        <TableColumn fx:id="colDate" prefWidth="200.0" text="Exam Date" />
                        <TableColumn fx:id="colRoom" prefWidth="150.0" text="Classroom" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>