<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<VBox spacing="25.0" style="-fx-background-color: white; -fx-padding: 30;" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.TaskFormController">
    <children>
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Create New Task" />
                <Label style="-fx-text-fill: #7f8c8d;" text="Add a new academic task to your dashboard" />
            </children>
        </VBox>

        <GridPane hgap="20.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints prefWidth="120.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Task Title" />
                <TextField fx:id="titleField" prefHeight="40.0" promptText="e.g. Finish homework" style="-fx-background-color: #f1f3f5; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8;" GridPane.columnIndex="1" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Description" GridPane.rowIndex="1" />
                <TextArea fx:id="descArea" prefHeight="80.0" promptText="Enter task details..." style="-fx-background-color: #f1f3f5; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8;" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Subject" GridPane.rowIndex="2" />
                <ComboBox fx:id="subjectCombo" prefHeight="40.0" prefWidth="Infinity" promptText="Select related subject" style="-fx-background-color: #f1f3f5;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Due Date" GridPane.rowIndex="3" />
                <DatePicker fx:id="dueDatePicker" prefHeight="40.0" prefWidth="Infinity" style="-fx-background-color: #f1f3f5;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Priority" GridPane.rowIndex="4" />
                <ComboBox fx:id="priorityCombo" prefHeight="40.0" prefWidth="Infinity" promptText="Set importance" style="-fx-background-color: #f1f3f5;" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Status" GridPane.rowIndex="5" />
                <CheckBox fx:id="completedCheckBox" mnemonicParsing="false" text="Mark as completed" style="-fx-text-fill: #6c757d;" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            </children>
        </GridPane>

        <Label fx:id="formStatusLabel" wrapText="true" />

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="Cancel" />
                <Button onAction="#handleSave" prefHeight="40.0" prefWidth="150.0" styleClass="action-button" text="Save Task" />
            </children>
        </HBox>
    </children>
</VBox>