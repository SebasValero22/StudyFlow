<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #F4F7FA; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.OverviewController">
    <children>
        <Label text="Resumen Académico" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <HBox spacing="20.0">
            <children>
                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: #34495e; -fx-background-radius: 10;">
                    <children>
                        <Label fx:id="lblTasksCount" text="3 Tareas para hoy" textFill="WHITE" wrapText="true">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: #27ae60; -fx-background-radius: 10;">
                    <children>
                        <Label fx:id="lblNextExam" text="Próximo Examen: Física" textFill="WHITE" wrapText="true">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: #2980b9; -fx-background-radius: 10;">
                    <children>
                        <Label fx:id="lblGPA" text="Media Total: 8.5" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Filtrar por periodo: " style="-fx-font-weight: bold;"/>
            <javafx.scene.control.ComboBox fx:id="timeframeCombo" prefWidth="150"/>
        </HBox>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <Label text="Próximas Tareas" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <javafx.scene.control.TableView fx:id="tasksTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <javafx.scene.control.TableColumn fx:id="colTaskTitle" text="Tarea" prefWidth="150"/>
                            <javafx.scene.control.TableColumn fx:id="colTaskDate" text="Fecha Límite" prefWidth="100"/>
                        </columns>
                        <columnResizePolicy>
                            <javafx.scene.control.TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </javafx.scene.control.TableView>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <Label text="Próximos Exámenes" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <javafx.scene.control.TableView fx:id="examsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <javafx.scene.control.TableColumn fx:id="colExamName" text="Examen" prefWidth="150"/>
                            <javafx.scene.control.TableColumn fx:id="colExamDate" text="Fecha" prefWidth="100"/>
                        </columns>
                        <columnResizePolicy>
                            <javafx.scene.control.TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </javafx.scene.control.TableView>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>