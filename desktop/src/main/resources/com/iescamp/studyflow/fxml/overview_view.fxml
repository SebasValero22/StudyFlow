<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #F4F7FA; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.OverviewController">
    <children>
        <Label text="Academic Overview" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <HBox spacing="20.0">
            <children>
                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: #34495e; -fx-background-radius: 10;">
                    <children>
                        <Label fx:id="lblTasksCount" text="Tasks pending" textFill="WHITE" wrapText="true">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: #27ae60; -fx-background-radius: 10;">
                    <children>
                        <Label fx:id="lblNextExam" text="Next Exam" textFill="WHITE" wrapText="true">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: #2980b9; -fx-background-radius: 10;">
                    <children>
                        <Label fx:id="lblGPA" text="GPA" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Filter by period: " style="-fx-font-weight: bold;"/>
            <javafx.scene.control.ComboBox fx:id="timeframeCombo" prefWidth="150"/>
        </HBox>

        <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <Label text="Upcoming Activities" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <javafx.scene.control.TableView fx:id="activityTable" VBox.vgrow="ALWAYS">
                <columns>
                    <javafx.scene.control.TableColumn fx:id="colType" text="Type" prefWidth="80"/>
                    <javafx.scene.control.TableColumn fx:id="colTitle" text="Activity" prefWidth="300"/>
                    <javafx.scene.control.TableColumn fx:id="colSubject" text="Subject" prefWidth="150"/>
                    <javafx.scene.control.TableColumn fx:id="colDate" text="Due Date" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <javafx.scene.control.TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </javafx.scene.control.TableView>
        </VBox>
    </children>
</VBox>