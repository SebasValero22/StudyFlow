<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iescamp.studyflow.controller.SubjectsController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="My Subjects" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Button onAction="#handleCreateSubject" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="+ New Subject" />
        <Button onAction="#handleEditSubject" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Edit Selected" />
        <Button onAction="#handleDeleteSubject" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete Selected" />
    </HBox>

    <javafx.scene.control.SplitPane dividerPositions="0.4" VBox.vgrow="ALWAYS">
        <items>
            <VBox spacing="10">
                <children>
                    <TableView fx:id="subjectsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="50">
                                <cellValueFactory><PropertyValueFactory property="subjectId" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn fx:id="nameColumn" text="Name" prefWidth="200">
                                <cellValueFactory><PropertyValueFactory property="nameSubject" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Year" prefWidth="100">
                                <cellValueFactory><PropertyValueFactory property="academicYear" /></cellValueFactory>
                            </TableColumn>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </children>
            </VBox>

            <VBox spacing="15" style="-fx-padding: 0 0 0 15;">
                <children>
                    <Label text="Subject Details" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                    
                    <VBox spacing="5" VBox.vgrow="SOMETIMES">
                        <Label text="Related Tasks" style="-fx-font-weight: bold;"/>
                        <TableView fx:id="tasksTable" prefHeight="150">
                            <columns>
                                <TableColumn fx:id="colTaskTitle" text="Title" prefWidth="200"/>
                                <TableColumn fx:id="colTaskDate" text="Due Date" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox spacing="5" VBox.vgrow="SOMETIMES">
                        <Label text="Related Exams" style="-fx-font-weight: bold;"/>
                        <TableView fx:id="examsTable" prefHeight="150">
                            <columns>
                                <TableColumn fx:id="colExamName" text="Exam" prefWidth="200"/>
                                <TableColumn fx:id="colExamDate" text="Date" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox spacing="5" VBox.vgrow="SOMETIMES">
                        <Label text="Grades" style="-fx-font-weight: bold;"/>
                        <TableView fx:id="gradesTable" prefHeight="150">
                            <columns>
                                <TableColumn fx:id="colGradeConcept" text="Concept" prefWidth="200"/>
                                <TableColumn fx:id="colGradeScore" text="Score" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>
                </children>
            </VBox>
        </items>
    </javafx.scene.control.SplitPane>

    <Label fx:id="statusLabel" textFill="RED" />
</VBox>